# ==========================================
# Bracket Challenge - Gitignore
# ==========================================

# -----------------
# Environment & IDE
# -----------------
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# -----------------
# Application Run-time
# -----------------
# Do NOT commit the active database configuration.
admin/database.php

# Ignore the installation lock file generated by the setup wizard
admin/install.lock

# Log files generated by the application
admin/logs/*
!admin/logs/.placeholder


# Service worker cache/build artifacts (if any)
.workbox-cache/
workbox-*.js
