// -------------------------------------------------------------
// Database Connection Safety Logic
// -------------------------------------------------------------

// 1. Detect "Not Configured" State (Placeholders or Empty)
// Checks if values match the Git-committed defaults or are missing.
$is_placeholder = (
    (isset($database) && $database === 'bracket_db') && 
    (isset($user) && $user === 'username') && 
    (isset($pass) && $pass === 'pw')
);
$is_empty = (empty($database) || empty($user) || empty($host));

if ($is_placeholder || $is_empty) {
    // If we are NOT in the installer, stop and show the Setup splash.
    // If we ARE in the installer, we let it proceed so it can write the config.
    if (!defined('INSTALLER_MODE')) {
        require_once __DIR__ . '/../includes/setup_required.php';
        exit();
    }
    // If Installer Mode, we return to let install.php continue (db_connected remains false)
    return;
}

// 2. Wrap Connection in Try/Catch
try {
	$dsn = "mysql:host=$host;dbname=$database;charset=utf8mb4";
	$options = [
		PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
		PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
		PDO::ATTR_EMULATE_PREPARES => false,
	];
	$db = new PDO($dsn, $user, $pass, $options);
} catch (\PDOException $e) {
    // If installation is in progress, suppress fatal error so wizard can show "Connection Failed" message if needed
    if(defined('INSTALLER_MODE')) return;
    
    // Otherwise, show safe "Service Unavailable" page
    require_once __DIR__ . '/../includes/service_unavailable.php';
	exit();
}

